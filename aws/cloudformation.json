{
  "Comment": "CloudFormation-style template for Food Bank Intake REST API on AWS API Gateway + Lambda",
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Foodbank Intake REST API infrastructure",
  "Parameters": {
    "Environment": {
      "Type": "String",
      "Default": "dev",
      "AllowedValues": ["dev", "staging", "prod"]
    }
  },
  "Resources": {
    "FoodbankApiGateway": {
      "Type": "AWS::ApiGateway::RestApi",
      "Properties": {
        "Name": "FoodbankIntakeAPI",
        "Description": "REST API for Foodbank Intake system",
        "EndpointConfiguration": {
          "Types": ["REGIONAL"]
        }
      }
    },
    "FoodbankLambdaRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "FoodbankLambdaExecutionRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": { "Service": "lambda.amazonaws.com" },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole",
          "arn:aws:iam::aws:policy/AmazonDynamoDBFullAccess"
        ]
      }
    },
    "ClientsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "FoodbankClients",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "id", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "id", "KeyType": "HASH" }
        ]
      }
    },
    "InventoryTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "FoodbankInventory",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "id", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "id", "KeyType": "HASH" }
        ]
      }
    },
    "IntakesTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "FoodbankIntakes",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          { "AttributeName": "id", "AttributeType": "S" }
        ],
        "KeySchema": [
          { "AttributeName": "id", "KeyType": "HASH" }
        ]
      }
    },
    "FrontendBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": { "Fn::Sub": "foodbank-intake-frontend-${Environment}" },
        "WebsiteConfiguration": {
          "IndexDocument": "index.html",
          "ErrorDocument": "index.html"
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": false,
          "BlockPublicPolicy": false,
          "IgnorePublicAcls": false,
          "RestrictPublicBuckets": false
        }
      }
    }
  }
}
