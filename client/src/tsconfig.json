{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "outDir": "./build",
    "allowSyntheticDefaultImports": true,
    "types": [
      "jest",
      "node"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "__test__/**/*.ts",
    "./**/*.ts",
    "secrets/**/*.json"
  ],
  "exclude": [
    "build",
    "node_modules"
  ]
}